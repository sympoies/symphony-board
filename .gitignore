# Build output.
dist/
dist-standalone/
target/
packages/desktop/src-tauri/gen/
packages/desktop-standalone/src-tauri/gen/

# Node runtime copied in as the standalone app's bundled sidecar.
packages/desktop-standalone/src-tauri/binaries/

