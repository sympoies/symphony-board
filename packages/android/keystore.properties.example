# Local release-signing config for `pnpm android:build:apk`. Copy to
# `keystore.properties` (gitignored) and fill in. CI does NOT use this file — it
# reads the keystore from repo secrets (ANDROID_KEYSTORE_BASE64 + passwords).
#
# storeFile may be absolute or relative to packages/android/.
storeFile=/absolute/path/to/symphony-board-release.jks
storePassword=CHANGE_ME
keyAlias=symphony-board
keyPassword=CHANGE_ME
