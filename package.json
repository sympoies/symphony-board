{
  "name": "symphony-board",
  "version": "1.1.3",
  "private": true,
  "description": "Provider-agnostic work-item board: aggregate GitHub/GitLab issues & PR/MRs into SQLite and emit a versioned JSON contract.",
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "prepare": "lefthook install",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --disable-warning=ExperimentalWarning --test test/*.test.ts",
    "test:pg-e2e": "bash scripts/ci/pg-e2e.sh",
    "coverage": "bash scripts/ci/coverage.sh",
    "coverage:badge": "bash scripts/ci/coverage-badge.sh coverage/lcov.info badges/coverage.svg",
    "init-db": "node --disable-warning=ExperimentalWarning src/cli/init-db.ts",
    "sync": "node --disable-warning=ExperimentalWarning src/cli/sync.ts",
    "emit": "node --disable-warning=ExperimentalWarning src/cli/emit-contract.ts",
    "validate": "node --disable-warning=ExperimentalWarning src/cli/validate-contract.ts",
    "desktop:dev": "pnpm --filter @symphony-board/desktop dev",
    "desktop:build": "pnpm --filter @symphony-board/desktop build",
    "desktop-standalone:dev": "pnpm --filter @symphony-board/desktop-standalone dev",
    "desktop-standalone:build": "pnpm --filter @symphony-board/desktop-standalone build"
  },
  "dependencies": {
    "@symphony-board/contract": "workspace:*",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "c8": "^10.1.3",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.0"
  }
}
