{
  "name": "symphony-board",
  "version": "1.2.4",
  "private": true,
  "description": "Provider-agnostic work-item board: aggregate GitHub/GitLab issues & PR/MRs into a canonical store and emit a versioned JSON contract.",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "prepare": "lefthook install",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:app-versions": "bash scripts/check-app-versions.sh",
    "test": "node --disable-warning=ExperimentalWarning --test test/*.test.ts test/*.test.mjs",
    "test:pg-e2e": "bash scripts/ci/pg-e2e.sh",
    "test:pg-compose": "bash scripts/ci/pg-compose-smoke.sh",
    "coverage": "bash scripts/ci/coverage.sh",
    "coverage:badge": "bash scripts/ci/coverage-badge.sh coverage/lcov.info badges/coverage.svg",
    "init-db": "node --disable-warning=ExperimentalWarning src/cli/init-db.ts",
    "sync": "node --disable-warning=ExperimentalWarning src/cli/sync.ts",
    "emit": "node --disable-warning=ExperimentalWarning src/cli/emit-contract.ts",
    "validate": "node --disable-warning=ExperimentalWarning src/cli/validate-contract.ts",
    "review-candidates": "node --disable-warning=ExperimentalWarning src/cli/review-candidates.ts",
    "desktop:dev": "pnpm --filter @symphony-board/desktop dev",
    "desktop:build": "pnpm --filter @symphony-board/desktop build",
    "android:init": "pnpm --filter @symphony-board/android run init",
    "android:dev": "pnpm --filter @symphony-board/android run dev",
    "android:run": "pnpm --filter @symphony-board/android run run",
    "android:build": "pnpm --filter @symphony-board/android run build",
    "android:build:apk": "pnpm --filter @symphony-board/android run build:apk",
    "android:info": "pnpm --filter @symphony-board/android run info",
    "desktop-standalone:dev": "pnpm --filter @symphony-board/desktop-standalone dev",
    "desktop-standalone:build": "pnpm --filter @symphony-board/desktop-standalone build"
  },
  "dependencies": {
    "@symphony-board/contract": "workspace:*",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.0.0",
    "c8": "^10.1.3",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.0"
  }
}
