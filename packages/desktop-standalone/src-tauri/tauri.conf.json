{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Symphony Board Standalone",
  "version": "1.7.3",
  "identifier": "com.sympoies.symphony-board.standalone",
  "build": {
    "beforeDevCommand": "bash scripts/prepare-node-sidecar.sh && VITE_SYMPHONY_BOARD_SERVER_URL=http://127.0.0.1:8787/ pnpm --dir ../.. --filter @symphony-board/ui dev -- --host 127.0.0.1 --port 5174",
    "beforeBuildCommand": "bash scripts/prepare-node-sidecar.sh && pnpm --dir ../.. --filter @symphony-board/ui run build:standalone",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../../ui/dist-standalone"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Symphony Board Standalone",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "category": "DeveloperTool",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": {
      "../../../package.json": "backend/package.json",
      "../../../tsconfig.json": "backend/tsconfig.json",
      "../../../src": "backend/src",
      "../../../schema": "backend/schema",
      "../../../packages/contract": "backend/packages/contract"
    },
    "shortDescription": "Self-contained desktop app for Symphony Board.",
    "longDescription": "A fully standalone Symphony Board: the read-only UI plus the bundled Node sync daemon, SQLite store, and contract server in one app. Config, tokens, and data live in the user's Application Support directory; no Docker or external server is required."
  }
}
