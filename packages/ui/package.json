{
  "name": "@symphony-board/ui",
  "version": "0.1.0",
  "private": true,
  "description": "symphony-board UI: a read-only board that consumes the versioned JSON contract (@symphony-board/contract).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:standalone": "tsc -p tsconfig.json --noEmit && VITE_SYMPHONY_BOARD_CLIENT=standalone VITE_SYMPHONY_BOARD_SERVER_URL=http://127.0.0.1:8787/ vite build --outDir dist-standalone --emptyOutDir",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --disable-warning=ExperimentalWarning --test test/*.test.ts",
    "smoke": "node --disable-warning=ExperimentalWarning scripts/render-smoke.mjs",
    "smoke:standalone": "SYMPHONY_BOARD_SMOKE_DIST=dist-standalone SYMPHONY_BOARD_SMOKE_STANDALONE=1 node --disable-warning=ExperimentalWarning scripts/render-smoke.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@symphony-board/contract": "workspace:*",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@xyflow/react": "^12.3.0",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^6.0.0",
    "vite": "^8.1.0"
  }
}
