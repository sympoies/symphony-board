{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "default",
  "description": "Default permissions for the Symphony Board Android thin client.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" },
        { "url": "http://*:*" },
        { "url": "https://*:*" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$APPLOCALDATA/*" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$APPLOCALDATA/*" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPLOCALDATA/*" }]
    }
  ]
}
