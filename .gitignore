node_modules/
*.log

# Local DB and its WAL/SHM/lease sidecars (never commit the store).
*.db
*.db-wal
*.db-shm
*.db-lease
data/

# Secrets and local config overrides.
.env
!.env.example
config/sources.json
config/sources.pg.json
config/secrets.env
config/certs/

# Operator-local Docker Compose overrides (never committed). Docker accepts both
# the `compose.*` and `docker-compose.*` names and both the `.yaml` and `.yml`
# spellings, at the repo root or under docker/ — the leading `*` (and no leading
# slash) covers every variant in every directory so an override using any
# supported filename can never be staged with secrets or bind addresses.
*compose.override.yaml
*compose.override.yml

# Emitted contract artifacts (regenerate from the DB).
out/
*.contract.json

# Build output.
dist/
dist-standalone/
target/
packages/desktop/src-tauri/gen/
packages/desktop-standalone/src-tauri/gen/
packages/android/src-tauri/gen/

# Node runtime copied in as the standalone app's bundled sidecar.
packages/desktop-standalone/src-tauri/binaries/

# Local coverage output (regenerate with `pnpm coverage`). The published badge
# lives on the `coverage-badge` orphan branch, not in the working tree.
coverage/

# Project-local Claude directory (skills live in .agents/skills/)
.claude/
