{
  "$comment": "Copy to config/sources.pg.json for docker/compose.pg.yaml. This is the Postgres variant of sources.example.json: db_url_env names the env var containing the postgres:// URL. docker/compose.pg.yaml sets SYMPHONY_DB_URL to its internal Postgres service by default; override it for an external database. Recommended GitHub auth uses auth_pools plus source/repo auth_policy. PAT pools keep failover semantics; GitHub App bot pools can route by observed rate-limit budgets. Legacy token_env/github_app/token_pools still work. Set enabled:false to keep a source in config but skip sync runs.",
  "db_path": "data/symphony.db",
  "db_url_env": "SYMPHONY_DB_URL",
  "$comment_db_path": "db_path is still required by the shared config schema but is unused when db_url_env selects Postgres.",
  "$comment_timezone": "Optional IANA timezone the board buckets calendar days in (e.g. \"Asia/Taipei\"). Omit or leave empty for UTC.",
  "timezone": "Asia/Taipei",
  "sources": [
    {
      "source_id": "github:github.com",
      "kind": "github",
      "host": "github.com",
      "display_name": "GitHub",
      "color": "#1f6feb",
      "auth_pools": {
        "source_pat": {
          "kind": "pat",
          "token_env": "GITHUB_TOKEN",
          "fallback_token_envs": ["GITHUB_TOKEN_BACKUP"]
        },
        "example_public": {
          "kind": "pat",
          "token_env": "GITHUB_TOKEN_EXAMPLE_PUBLIC",
          "fallback_token_envs": ["GITHUB_TOKEN_EXAMPLE_PUBLIC_BACKUP"]
        },
        "example_partner": {
          "kind": "pat",
          "token_env": "GITHUB_TOKEN_EXAMPLE_PARTNER",
          "fallback_token_envs": ["GITHUB_TOKEN_EXAMPLE_PARTNER_BACKUP"]
        },
        "example_bots": {
          "kind": "github_app",
          "strategy": "budget_aware",
          "apps": [
            {
              "name": "example-bot-a",
              "app_id_env": "EXAMPLE_BOT_A_APP_ID",
              "installation_id_env": "EXAMPLE_BOT_A_INSTALLATION_ID",
              "private_key_path_env": "EXAMPLE_BOT_A_PRIVATE_KEY_PATH"
            },
            {
              "name": "example-bot-b",
              "app_id_env": "EXAMPLE_BOT_B_APP_ID",
              "installation_id_env": "EXAMPLE_BOT_B_INSTALLATION_ID",
              "private_key_path_env": "EXAMPLE_BOT_B_PRIVATE_KEY_PATH"
            }
          ]
        }
      },
      "auth_policy": { "mode": "pat", "pat_pool": "source_pat" },
      "graphql_url": "https://api.github.com/graphql",
      "rest_url": "https://api.github.com",
      "projects": [
        { "path": "example-org/public-roadmap", "auth_policy": { "mode": "pat", "pat_pool": "example_public" } },
        "example-org/service-api",
        { "path": "partner-org/mobile-client", "auth_policy": { "mode": "pat", "pat_pool": "example_partner" } },
        { "path": "partner-org/internal-tools", "color": "#e0af68", "auth_policy": { "mode": "bot", "bot_pool": "example_bots" } },
        { "path": "example-org/bot-readable-repo", "auth_policy": { "mode": "bot_then_pat", "bot_pool": "example_bots", "pat_pool": "source_pat" } }
      ]
    },
    {
      "source_id": "gitlab:gitlab.com",
      "kind": "gitlab",
      "host": "gitlab.com",
      "display_name": "GitLab",
      "enabled": true,
      "token_env": "GITLAB_TOKEN",
      "graphql_url": "https://gitlab.com/api/graphql",
      "rest_url": "https://gitlab.com/api/v4",
      "projects": [
        "your-group/your-project",
        "your-group/your-subgroup/another-project"
      ]
    }
  ],
  "identities": [
    {
      "name": "Your Name",
      "usernames": ["your-gitlab-username"],
      "emails": ["you@example.com"],
      "names": ["Your Name", "Y. Name"],
      "source_ids": ["gitlab:gitlab.com"]
    }
  ],
  "exclude_actors": ["dependabot", "github-code-quality", "renovate*"]
}
